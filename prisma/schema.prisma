generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// в”Ђв”Ђ Enums в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum ProductCategory {
  everyday
  pushup
  lace
  sports
  seamless
  plus
  bridal
}

enum BadgeType {
  Bestseller
  New
  Sale
  Premium
  ComfortFit
}

enum SupportLevel {
  Light
  Medium
  High
}

enum ImageType {
  front
  back
  lifestyle
  detail
}

// в”Ђв”Ђ Category в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// One row per product category. Slug is the canonical identifier used in URLs
// and filters. Adding a new category is a data change, not a schema migration.

model Category {
  id          Int             @id @default(autoincrement())
  slug        ProductCategory @unique
  label       String
  description String?
  imageUrl    String?
  sortOrder   Int             @default(0)
  products    Product[]
}

// в”Ђв”Ђ Product в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Core product record. `rating` and `reviewCount` are denormalised aggregates
// recomputed whenever a Review is created/deleted (a background job or trigger).
// `sizes` is a display-only label вЂ” not queryable by individual size.

model Product {
  id          Int            @id @default(autoincrement())
  name        String
  story       String
  sub         String
  price       Int
  oldPrice    Int?
  emoji       String
  badge       BadgeType?
  categoryId  Int
  category    Category       @relation(fields: [categoryId], references: [id])
  rating      Float
  reviewCount Int
  fabric      String
  support     SupportLevel
  sizes       String
  isActive    Boolean        @default(true)
  images      ProductImage[]
  reviews     Review[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([categoryId])
  @@index([support])
  @@index([price])
  @@index([rating])
}

// в”Ђв”Ђ ProductImage в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Each image is its own row. `position` controls display order (0 = hero).
// `type` allows the gallery to distinguish front/back/lifestyle shots.
// `blurDataURL` stores a tiny base64 placeholder for the primary image.

model ProductImage {
  id          Int       @id @default(autoincrement())
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  url         String
  key         String?
  alt         String?
  position    Int       @default(0)
  type        ImageType @default(front)
  isPrimary   Boolean   @default(false)
  blurDataURL String?

  @@index([productId, position])
}

// в”Ђв”Ђ Review в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Individual customer review. `rating` is 1вЂ“5. The product's `rating` /
// `reviewCount` fields are denormalised summaries of this table.

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int
  body      String?
  author    String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
}

// в”Ђв”Ђ Order в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// One row per customer order. Address fields are denormalised (no reuse needed).
// Totals are recalculated server-side on creation вЂ” client values are ignored.

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
}

enum PaymentMethod {
  upi
  card
  netbanking
  cod
}

model Order {
  id            String        @id
  status        OrderStatus   @default(pending)
  paymentMethod PaymentMethod
  couponCode    String?

  // Totals вЂ” all in INR paise-less integers
  subtotal      Int
  shipping      Int
  discount      Int           @default(0)
  total         Int

  // Shipping address (denormalised)
  firstName     String
  lastName      String
  email         String
  phone         String
  addressLine   String
  city          String
  state         String
  pinCode       String

  items         OrderItem[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

// в”Ђв”Ђ OrderItem в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// One row per line in an order. `productId` is null for custom bra items.
// `priceAtOrder` locks the price at the time of purchase.

model OrderItem {
  id           Int      @id @default(autoincrement())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    Int?
  name         String
  size         String
  qty          Int
  priceAtOrder Int
  customSpec   Json?

  @@index([orderId])
}

// в”Ђв”Ђ SavedDesign в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Builder designs saved by the user. specHash deduplicates identical specs so
// the AI image is generated at most once per unique configuration.

model SavedDesign {
  id         String   @id @default(cuid())
  specHash   String   @unique
  specJson   Json
  previewUrl String?
  createdAt  DateTime @default(now())

  @@index([specHash])
}
